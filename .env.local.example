# ============================================================
# Masaar — Environment Variables
# Copy this to `.env.local` and fill in the values from Supabase.
# ============================================================

# Public URL of your deployed app (used to build QR redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — NEVER expose to the client.
# Used only in server-side admin operations (optional for v1).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
