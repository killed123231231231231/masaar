# Supabase — project hsnrupadmygkeirhujiv (region ap-south-1)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Absolute origin used to build dynamic-QR /r/ links. On Vercel preview
# builds this is intentionally a placeholder (https://preview.invalid).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-only. Never expose. Used by privileged server paths only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Payment lock-in flag. false = checkout stub activates QRs directly
# (no billing). true = Stripe Checkout (not implemented yet — Sprint 3).
PAYMENTS_ENABLED=false

# Transactional email via Resend (welcome email + /contact notification).
# All optional: if RESEND_API_KEY is unset or isn't a real key (must start
# with "re_"), email STUBS — the HTML is built and logged but nothing is
# sent, so local/preview never emails real users.
RESEND_API_KEY=re_your-resend-key
# Verified sender. Defaults to "Masaar <onboarding@resend.dev>" if unset.
RESEND_FROM=Masaar <onboarding@resend.dev>
# Inbox that receives /contact form submissions. Defaults to hello@masaar.sa.
RESEND_NOTIFY_TO=hello@masaar.sa
